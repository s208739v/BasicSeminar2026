# ==========================================
# uv / 仮想環境（絶対にGitに入れない）
# ==========================================
.venv/

# ==========================================
# Python特有のキャッシュ（自動生成されるゴミ箱）
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==========================================
# 環境変数・秘密情報（パスワードやAPIキーなど）
# ==========================================
.env
.env.local

# ==========================================
# OS固有のゴミファイル
# ==========================================
.DS_Store
Thumbs.db